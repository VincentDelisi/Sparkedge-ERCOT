# Sparkedge ERCOT — environment configuration (all optional)
# Copy to .env and export, or set these in your shell / deployment.

# EIA API key for Henry Hub daily spot gas prices.
# Get one free at https://www.eia.gov/opendata/register.php
# ERCOT has no per-hub gas feed, so Henry Hub is the reference gas for every hub.
# If unset, gas is unavailable and implied heat rates / spark spreads show n/a
# (prices, load, fuel mix, and the duck curve still work).
EIA_API_KEY=

# Override the SQLite cache location (default: ~/.sparkedge_ercot/sparkedge_ercot.db)
# SPARKEDGE_DB_PATH=/data/sparkedge_ercot.db
# SPARKEDGE_HOME=/data/sparkedge

# Rolling-window stats
# SPARKEDGE_ROLLING_DAYS=30
# SPARKEDGE_SIGMA=2.0

# Gas source preference: "eia" (Henry Hub, default and only source for ERCOT)
# SPARKEDGE_GAS_SOURCE=eia

# Inter-request sleep passed to gridstatus / between pulls (seconds)
# SPARKEDGE_OASIS_SLEEP=3

# Relax TLS verification for ERCOT hosts ONLY. Enable this if load / fuel-mix
# (the duck curve) fail with: SSL: CERTIFICATE_VERIFY_FAILED. Common on
# corporate networks, VPNs, or HTTPS-inspecting antivirus. Scoped to public
# ERCOT data; all other HTTPS stays fully verified. Set to 1 to enable.
# SPARKEDGE_INSECURE_SSL=1
